[colors]
background = #000000
background-alt = #373B41
foreground = #ffffff
primary = #B9D9FB
secondary = #30cbff
alert = #A54242
disabled = #979797
orange = #FF5520
green = #9ACD83

[bar/mybar]
width = 100%
height = 25pt
radius = 0

; dpi = 96

background = ${colors.background}
foreground = ${colors.foreground}

line-size = 3pt

border-size = 0pt
border-color = #000000

padding-left = 0
padding-right = 0

module-margin = 1

separator = |
separator-foreground = ${colors.disabled}

# font-0 = "Ubuntu Sans:size=14;4"
font-0 = "JetBrainsMono Nerd Font:size=11"
font-1 = "Noto Color Emoji:scale=8"
# font-2 = "icomoon;4"

modules-left = rofi xworkspaces xwindow
# modules-right = pulseaudio battery memory cpu wlan date powermenu
modules-right = weather pulseaudio memory battery wlan date wallpaper powermenu

cursor-click = pointer
cursor-scroll = ns-resize

enable-ipc = true

tray-position = right
wm-restack = i3


; override-redirect = true

[module/rofi]
type = custom/text
content = "яГЙ"
content-background = ${colors.background}
content-foreground = ${colors.secondary}
content-padding = 1
click-left = "rofi -show drun"

[module/xworkspaces]
type = internal/xworkspaces

label-active = %name%
label-active-background = ${colors.background-alt}
label-active-underline= ${colors.primary}
label-active-padding = 1

label-occupied = %name%
label-occupied-padding = 1

label-urgent = %name%
label-urgent-background = ${colors.alert}
label-urgent-padding = 1

label-empty = %name%
label-empty-foreground = ${colors.disabled}
label-empty-padding = 1

enable-scroll = true
show-urgent = true
;icon-0 = 1;яВм
;icon-1 = 2;яЙи
;icon-2 = 3;яДа
;icon-3 = 4;яДб
;icon-4 = 5;яБ╝
;icon-5 = 6;яЙм
;icon-6 = 7;яЖ╝
;icon-7 = 8;яБД
;icon-8 = 9;яЖЭ
;icon-9 = 10;яЗШ
;icon-default = тЩЯ

[module/xwindow]
type = internal/xwindow
label = %title:0:70:...%

[module/pulseaudio]
type = internal/pulseaudio
format-volume-prefix = "ЁЯФК "
format-volume-prefix-foreground = ${colors.green}
format-volume = <label-volume>
label-volume = %percentage%%
label-muted = ЁЯФЗ muted
label-muted-foreground = ${colors.disabled}
;Right and Middle click
click-right = pavucontrol
; click-middle =

[module/xkeyboard]
type = internal/xkeyboard
blacklist-0 = num lock

label-layout = %layout%
label-layout-foreground = ${colors.primary}

label-indicator-padding = 2
label-indicator-margin = 1
label-indicator-foreground = ${colors.background}
label-indicator-background = ${colors.secondary}

[module/memory]
type = internal/memory
interval = 3
format-prefix = "ЁЯРП "
format-prefix-foreground = ${colors.primary}
label = %percentage_used:2%%
click-left = "alacritty --class "term,term" -e htop"

[module/cpu]
type = internal/cpu
interval = 3
format-prefix = " яЛЫ  CPU "
format-prefix-foreground = ${colors.primary}
label = %percentage:2%%
click-left = "alacritty --class "term,term" -e auto-cpufreq --stats"

[network-base]
type = internal/network
interval = 5
format-connected = <label-connected>
format-disconnected = <label-disconnected>
label-disconnected = %{F#F0C674}%ifname%%{F#707880} disconnected

[module/wlan]
inherit = network-base
interface-type = wireless
label-connected = ЁЯЫЬ %essid%

[module/date]
type = internal/date
interval = 1
date = %I:%M %p 
date-alt = %d-%m-%Y %I:%M:%S %p
label = ЁЯХШ %date%

[module/battery]
type = internal/battery
full-at = 99
low-at = 25
battery = BAT1
adapter = ACAD
poll-interval = 5
time-format = %H:%M
format-charging = <animation-charging>  <label-charging>
format-discharging = <ramp-capacity>  <label-discharging>
format-full = <ramp-capacity>  <label-full>
format-low = <label-low>  <animation-low>
label-charging =  ЁЯФМ %percentage%%
label-discharging =  ЁЯФ╗ %percentage%%
label-full = ЁЯТп Fully charged
label-low = ЁЯкл BATTERY LOW
ramp-capacity-0 = яЙД  
ramp-capacity-1 = яЙГ  
ramp-capacity-2 = яЙВ  
ramp-capacity-3 = яЙБ  
ramp-capacity-4 = яЙА  
bar-capacity-width = 10
animation-charging-0 = яЙД
animation-charging-1 = яЙГ 
animation-charging-2 = яЙВ 
animation-charging-3 = яЙБ 
animation-charging-4 = яЙА 
animation-charging-framerate = 750
animation-discharging-0 = яЙА 
animation-discharging-1 = яЙБ 
animation-discharging-2 = яЙВ 
animation-discharging-3 = яЙГ 
animation-discharging-4 = яЙД 
animation-discharging-framerate = 500
animation-low-0 = !
animation-low-1 = 
animation-low-framerate = 200

[module/powermenu]
type = custom/text
content-background = ${colors.background}
content-foreground = ${colors.orange}
content-padding = 1
click-left = "$HOME/bin/power-menu"
content = "тЭдя╕П"

[module/weather]
type = custom/script
exec = "bash -c $HOME/.config/polybar/scripts/weather"
content-background = ${colors.background}
interval = 3600

[module/wallpaper]
type = custom/text
content-background = ${colors.background}
click-left = "$HOME/bin/x11-wallpaper"
content-padding = 1
content = "ЁЯЦ╝я╕П"

[settings]
screenchange-reload = true
pseudo-transparency = true

; vim:ft=dosini
