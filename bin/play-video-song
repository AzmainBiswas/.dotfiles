#!/usr/bin/env bash

MENU="dmenu -i -F -l 30 -p"
# MENU="rofi -dmenu" # DONT WORK

ALL="/mnt/media/video/songs/"
BENGALI="/mnt/media/video/songs/bengali/"
ENGLISH="/mnt/media/video/songs/english/"
HINDI="/mnt/media/video/songs/hindi/"

LANG=$(printf "ALL\nBengali\nEnglish\nHindi" | ${MENU} "Sclect Language > ")

case "${LANG}" in
    Bengali)
	mpv --fs --loop $(find ${BENGALI} -type f -iname "*.webm" -o -iname "*.mp4" -o -iname "*.mkv" | ${MENU} "Sclect Video > ")
	;;
    English)
	mpv --fs --loop $(find ${ENGLISH} -type f -iname "*.webm" -o -iname "*.mp4" -o -iname "*.mkv" | ${MENU} "Sclect Video > ")
	;;
    Hindi)
	mpv --fs --loop $(find ${HINDI} -type f -iname "*.webm" -o -iname "*.mp4" -o -iname "*.mkv" | ${MENU} "Sclect Video > ")
	;;
    ALL)
	mpv --fs --loop $(find ${ALL} -type f -iname "*.webm" -o -iname "*.mp4" -o -iname "*.mkv" | ${MENU} "Sclect Video > ")
	;;
    *)
	printf "You choice in invalide. Run the script again" | ${MENU}
esac
