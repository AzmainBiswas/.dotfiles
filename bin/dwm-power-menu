#!/usr/bin/env bash

# action=$(printf "Shutdown\nLock\nSuspend\nHibernate\nReboot" | rofi -dmenu -case-sensitive -p "Power Menu")
action=$(printf "Shutdown\nLock\nLogout\nSuspend\nHibernate\nReboot" | dmenu -l 6 -i -F -p "Power Menu >")

case "${action}" in
Shutdown)
	systemctl poweroff
	;;
Lock)
	slock
	;;
Logout)
    pkill dwm
    ;;
Suspend)
	slock
	systemctl suspend
	;;
Hibernate)
	slock
	systemctl hibernate
	;;
Reboot)
	systemctl reboot
	;;
*)
	exit 2
	;;
esac

exit 0
